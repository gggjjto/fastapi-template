# 应用基础配置
# 项目名（展示在日志与文档）
APP_PROJECT_NAME=FastAPI Template

# 可选：development / staging / production / test
APP_ENV=development

# 调试开关，生产建议 false
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
# API 前缀
APP_API_V1_PREFIX=/api/v1

# 日志级别：DEBUG/INFO/WARNING/ERROR
APP_LOG_LEVEL=INFO
# 生产建议 true，输出结构化 JSON 日志
APP_LOG_JSON=false

# CORS 白名单，逗号分隔
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# 数据库与建表策略
# 开发可用 sqlite，生产请改 PostgreSQL
APP_DATABASE_URL=sqlite+aiosqlite:///./app.db
# 打开 SQLAlchemy 日志可用于排查 SQL
APP_SQLALCHEMY_ECHO=false
# 生产环境请设为 false（通过 Alembic 管理）
APP_DB_CREATE_TABLES_ON_STARTUP=true

# JWT 鉴权
# 建议使用：python -c "import secrets; print(secrets.token_hex(32))"
APP_JWT_SECRET=change-me-in-production-use-a-long-random-string
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
# refresh token 有效期（天）
APP_REFRESH_TOKEN_EXPIRE_DAYS=30
# 消息默认语言：en-US 或 zh-CN
APP_DEFAULT_LOCALE=en-US

# Redis（可选）：注释即关闭 Redis、缓存与 Arq
# APP_REDIS_URL=redis://localhost:6379/0

# Sentry（可选）：留空则关闭错误跟踪
# APP_SENTRY_DSN=https://<key>@sentry.io/<project>
