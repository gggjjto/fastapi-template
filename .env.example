# 应用基础配置
APP_PROJECT_NAME=FastAPI Template            # 项目名（展示在日志与文档）
APP_ENV=development                         # 可选：development / staging / production / test
APP_DEBUG=true                              # 调试开关，生产建议 false
APP_HOST=0.0.0.0                           # 监听地址；生产部署建议保留 0.0.0.0
APP_PORT=8000                               # 监听端口
APP_API_V1_PREFIX=/api/v1                   # API 前缀
APP_LOG_LEVEL=INFO                          # 日志级别：DEBUG/INFO/WARNING/ERROR
APP_LOG_JSON=false                          # 生产建议 true 输出结构化 JSON 日志
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000  # CORS 白名单，逗号分隔

# 数据库与建表策略
APP_DATABASE_URL=sqlite+aiosqlite:///./app.db # 开发可用 sqlite，生产请改 PostgreSQL
APP_SQLALCHEMY_ECHO=false                  # 打开 SQLAlchemy 日志可用于排查 SQL
APP_DB_CREATE_TABLES_ON_STARTUP=true        # 生产环境请设为 false（通过 Alembic 管理）

# JWT 鉴权
# 建议使用：python -c "import secrets; print(secrets.token_hex(32))"
APP_JWT_SECRET=change-me-in-production-use-a-long-random-string
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=30
APP_DEFAULT_LOCALE=en-US                     # 消息默认语言：en-US 或 zh-CN

# Redis（可选）：注释即关闭 Redis、缓存与 Arq
# APP_REDIS_URL=redis://localhost:6379/0

# Sentry（可选）：留空则关闭错误跟踪
# APP_SENTRY_DSN=https://<key>@sentry.io/<project>
