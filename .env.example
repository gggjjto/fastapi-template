APP_PROJECT_NAME=FastAPI Template
APP_ENV=development
APP_DEBUG=true
APP_HOST=0.0.0.0
APP_PORT=8000
APP_API_V1_PREFIX=/api/v1
APP_LOG_LEVEL=INFO
APP_LOG_JSON=false
APP_ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
APP_DATABASE_URL=sqlite+aiosqlite:///./app.db
APP_SQLALCHEMY_ECHO=false
APP_DB_CREATE_TABLES_ON_STARTUP=true

# JWT — generate a strong secret: python -c "import secrets; print(secrets.token_hex(32))"
APP_JWT_SECRET=change-me-in-production
APP_JWT_ALGORITHM=HS256
APP_ACCESS_TOKEN_EXPIRE_MINUTES=30
APP_REFRESH_TOKEN_EXPIRE_DAYS=30

# Redis — comment out to disable Redis, cache, and Arq task queue
# APP_REDIS_URL=redis://localhost:6379/0

# Sentry — leave empty to disable error tracking
# APP_SENTRY_DSN=https://<key>@sentry.io/<project>
